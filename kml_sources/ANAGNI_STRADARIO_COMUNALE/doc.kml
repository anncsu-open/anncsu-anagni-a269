.odd { font-family: Verdana, Geneva, Arial, Helvetica, sans-serif; color: #000000; background-color:#F0F0F0; border: 1px solid #000000;}
.caption { background-color: #000080; color:#ffffff; border: 2px solid #000080; padding: 2px; margin:0; min-width: 260px; max-width: 420px;}
.form { border: 2px solid #000080; padding: 2px; margin:0; overflow: auto; min-width: 260px; max-width: 420px;}
</style>
